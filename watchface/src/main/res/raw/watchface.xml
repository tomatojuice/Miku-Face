<?xml version="1.0" encoding="UTF-8"?>
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="ANALOG" />

    <UserConfigurations>
        <ListConfiguration
            id="background_image"
            displayName="@string/menu_title"
            screenReaderText="@string/menu_title"
            icon="@drawable/i_miku_1"
            defaultValue="0">
            <ListOption id="0" displayName="@string/character_miku_1" screenReaderText="@string/character_miku_1" icon="@drawable/i_miku_1" />
            <ListOption id="1" displayName="@string/character_miku_2" screenReaderText="@string/character_miku_2" icon="@drawable/i_miku_2" />
            <ListOption id="2" displayName="@string/character_gumi_1" screenReaderText="@string/character_gumi_1" icon="@drawable/i_gumi_1" />
            <ListOption id="3" displayName="@string/character_gumi_2" screenReaderText="@string/character_gumi_2" icon="@drawable/i_gumi_2" />
            <ListOption id="4" displayName="@string/character_kaito" screenReaderText="@string/character_kaito" icon="@drawable/i_kaito" />
            <ListOption id="5" displayName="@string/character_luka" screenReaderText="@string/character_luka" icon="@drawable/i_luka" />
            <ListOption id="6" displayName="@string/character_rinren" screenReaderText="@string/character_rinren" icon="@drawable/i_rinren" />
            <ListOption id="7" displayName="@string/character_teto" screenReaderText="@string/character_teto" icon="@drawable/i_teto" />
            <ListOption id="8" displayName="@string/character_yukari" screenReaderText="@string/character_yukari" icon="@drawable/i_yukari" />
            <ListOption id="9" displayName="@string/character_una" screenReaderText="@string/character_una" icon="@drawable/i_una_1" />
        </ListConfiguration>

        <ColorConfiguration
            id="hand_theme"
            displayName="@string/color_theme"
            defaultValue="cyber_colors">
            <ColorOption id="cyber_colors" displayName="@string/color_cyber" colors="#FF00FFFF #FFFF00FF #FFFFFF00" />
            <ColorOption id="default_colors" displayName="@string/color_default" colors="#FFFF0080 #FFFF9900 #FFFFE600" />
            <ColorOption id="neon_colors" displayName="@string/color_neon" colors="#FF00B2FF #FF00FF33 #FF80FF00" />
            <ColorOption id="mono_colors" displayName="@string/color_mono" colors="#FFFFFFFF #FFCCCCCC #FF888888" />
            <ColorOption id="crimson_colors" displayName="@string/color_crimson" colors="#FFFF0000 #FFFF8C00 #FFFFFF00" />
            <ColorOption id="toxic_colors" displayName="@string/color_toxic" colors="#FF8A2BE2 #FF32CD32 #FF9400D3" />
            <ColorOption id="sunset_colors" displayName="@string/color_sunset" colors="#FFFF7F50 #FF8A2BE2 #FFFFD700" />
            <ColorOption id="aqua_colors" displayName="@string/color_aqua" colors="#FF00FFFF #FF1E90FF #FF00FA9A" />
            <ColorOption id="voltage_colors" displayName="@string/color_voltage" colors="#FFFFE600 #FF00FFFF #FFADFF2F" />
        </ColorConfiguration>

        <BooleanConfiguration id="show_batt" displayName="@string/config_show_battery" defaultValue="FALSE" />
        <BooleanConfiguration id="smooth_sec" displayName="@string/config_smooth_seconds" defaultValue="FALSE" />
    </UserConfigurations>

    <Scene backgroundColor="#000000">

        <PartImage x="0" y="0" width="450" height="450" name="base_bg">
            <Image resource="image_wave_mint" />
            <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>

        <ListConfiguration id="background_image">
            <ListOption id="0"><PartImage x="0" y="0" width="450" height="450" name="p_miku_1"><Image resource="miku_1" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="1"><PartImage x="0" y="0" width="450" height="450" name="p_miku_2"><Image resource="miku_2" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="2"><PartImage x="0" y="0" width="450" height="450" name="p_gumi_1"><Image resource="gumi_1" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="3"><PartImage x="0" y="0" width="450" height="450" name="p_gumi_2"><Image resource="gumi_2" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="4"><PartImage x="0" y="0" width="450" height="450" name="p_kaito"><Image resource="kaito" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="5"><PartImage x="0" y="0" width="450" height="450" name="p_luka"><Image resource="luka" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="6"><PartImage x="0" y="0" width="450" height="450" name="p_rinren"><Image resource="rinren" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="7"><PartImage x="0" y="0" width="450" height="450" name="p_teto"><Image resource="teto" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="8"><PartImage x="0" y="0" width="450" height="450" name="p_yukari"><Image resource="yukari" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
            <ListOption id="9"><PartImage x="0" y="0" width="450" height="450" name="p_una"><Image resource="una_1" /><Variant mode="AMBIENT" target="alpha" value="0" /></PartImage></ListOption>
        </ListConfiguration>

        <Group x="0" y="0" width="450" height="450" name="indices">
            <Group name="idx_1" x="0" y="0" width="450" height="450" angle="0"><PartImage x="215" y="10" width="20" height="12" tintColor="#FF004D"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_2" x="0" y="0" width="450" height="450" angle="30"><PartImage x="215" y="10" width="20" height="12" tintColor="#FF4D00"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_3" x="0" y="0" width="450" height="450" angle="60"><PartImage x="215" y="10" width="20" height="12" tintColor="#FF9900"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_4" x="0" y="0" width="450" height="450" angle="90"><PartImage x="215" y="10" width="20" height="12" tintColor="#FFE600"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_5" x="0" y="0" width="450" height="450" angle="120"><PartImage x="215" y="10" width="20" height="12" tintColor="#80FF00"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_6" x="0" y="0" width="450" height="450" angle="150"><PartImage x="215" y="10" width="20" height="12" tintColor="#00FF33"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_7" x="0" y="0" width="450" height="450" angle="180"><PartImage x="215" y="10" width="20" height="12" tintColor="#00FFB2"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_8" x="0" y="0" width="450" height="450" angle="210"><PartImage x="215" y="10" width="20" height="12" tintColor="#00B2FF"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_9" x="0" y="0" width="450" height="450" angle="240"><PartImage x="215" y="10" width="20" height="12" tintColor="#0033FF"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_10" x="0" y="0" width="450" height="450" angle="270"><PartImage x="215" y="10" width="20" height="12" tintColor="#8000FF"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_11" x="0" y="0" width="450" height="450" angle="300"><PartImage x="215" y="10" width="20" height="12" tintColor="#FF00E6"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
            <Group name="idx_12" x="0" y="0" width="450" height="450" angle="330"><PartImage x="215" y="10" width="20" height="12" tintColor="#FF0080"><Image resource="index_stick_short_medium" /><Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" /></PartImage></Group>
        </Group>

        <BooleanConfiguration id="show_batt">
            <BooleanOption id="TRUE">
                <Group name="battery_group" x="0" y="0" width="450" height="450">
                    <PartDraw name="battery_bg" x="175" y="340" width="100" height="40">
                        <RoundRectangle x="0" y="0" width="100" height="40" cornerRadiusX="20" cornerRadiusY="20">
                            <Fill color="#BB000000" />
                            <Stroke color="[CONFIGURATION.hand_theme.0]" thickness="2" />
                        </RoundRectangle>
                        <Variant mode="AMBIENT" target="alpha" value="0" />
                    </PartDraw>
                    <PartText name="battery_value" x="175" y="340" width="100" height="40">
                        <Text align="CENTER">
                            <Font family="SYNC_TO_DEVICE" size="22" color="#FFFFFF" weight="BOLD">
                                <Template>%s%%<Parameter expression="[BATTERY_PERCENT]" /></Template>
                            </Font>
                        </Text>
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                    </PartText>
                </Group>
            </BooleanOption>
        </BooleanConfiguration>

        <BooleanConfiguration id="smooth_sec">
            <BooleanOption id="TRUE">
                <AnalogClock x="0" y="0" width="450" height="450">
                    <HourHand resource="hour_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.0]">
                        <Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" />
                    </HourHand>

                    <MinuteHand resource="min_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.1]">
                        <Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" />
                    </MinuteHand>

                    <SecondHand resource="sec_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.2]">
                        <Variant mode="AMBIENT" target="alpha" value="0" />
                        <Sweep frequency="15" />
                    </SecondHand>
                </AnalogClock>
            </BooleanOption>

            <BooleanOption id="FALSE">
                <AnalogClock x="0" y="0" width="450" height="450">
                    <HourHand resource="hour_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.0]">
                        <Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" />
                    </HourHand>

                    <MinuteHand resource="min_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.1]">
                        <Variant mode="AMBIENT" target="tintColor" value="#FFFFFF" />
                    </MinuteHand>

                    <SecondHand resource="sec_classic" x="200" y="0" width="50" height="450" pivotX="0.5" pivotY="0.5" tintColor="[CONFIGURATION.hand_theme.2]">
                        <Variant mode="AMBIENT" target="alpha" value="0" />
                    </SecondHand>
                </AnalogClock>
            </BooleanOption>
        </BooleanConfiguration>

    </Scene>
</WatchFace>